graph TD
    %% ---- Phase 1: Lower the Veil ----
    subgraph P1["帳をおろす"]
        CMD["/tobari feature-name"]
        STG0["STG0: 要件定義<br/>契約生成 + ユーザー承認"]
        CMD --> STG0
    end

    %% ---- Phase 2: Design & Implement ----
    subgraph P2["設計・実装"]
        STG1["STG1: 設計<br/>自動アプローチ決定"]
        STG2["STG2: 実装<br/>自動 + スコープ監視"]
        STG1 --> STG2
    end

    %% ---- Phase 3: Parallel Execution ----
    subgraph P3["並列実行"]
        TI["/team-implement<br/>Agent Teams 並列実装"]
        TR["/team-review<br/>並列レビュー<br/>セキュリティ・品質・テスト"]
        TI --> TR
    end

    %% ---- Phase 4: Auto-Complete ----
    subgraph P4["自動完了"]
        STG3["STG3: 検証<br/>テスト + lint"]
        STG4["STG4: 自動化<br/>CI/CD チェック"]
        STG5["STG5: コミット<br/>git-guard 経由で自動"]
        STG6["STG6: PR・マージ"]
        STG3 --> STG4 --> STG5 --> STG6
    end

    %% ---- Final ----
    LIFT["帳を解く<br/>tobari-session.json 削除"]

    %% ---- Phase Connections ----
    P1 --> P2 --> P3 --> P4
    STG6 --> LIFT

