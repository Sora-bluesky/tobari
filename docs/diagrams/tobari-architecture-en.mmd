%%{init: {'theme': 'dark'}}%%
graph TD
    %% ---- User Entry ----
    User(["👤 User"])

    %% ---- Orchestra Layer ----
    subgraph Orchestra["🎼 Orchestra Layer"]
        CC["Claude Code<br/>Orchestrator"]
        SA["Subagents<br/>Plan · Explore · general-purpose"]
        AT["Agent Teams<br/>Teammates (parallel)"]
        CC -->|delegate| SA
        CC -->|parallel dispatch| AT
    end

    %% ---- State / Data ----
    subgraph Data["📊 State & Evidence"]
        BL["backlog.yaml<br/>Task State (SoT)"]
        SJ["tobari-session.json<br/>Session State"]
        EV["Evidence Ledger<br/>Audit Trail (JSONL)"]
    end

    %% ---- Binding Layer ----
    subgraph Binding["🔒 Binding Layer (Claude Code Hooks)"]
        GE["Gate Engine<br/>allow / deny / ask<br/>PreToolUse Hook"]
        SC["Stage Controller<br/>STG0 → STG1 → STG2 → STG3 → STG4 → STG5 → STG6"]
    end

    %% ---- Vertical flow (no cycles) ----
    User -->|instruct| CC
    CC -->|read/write| BL
    CC -->|manage| SJ
    CC -->|record| EV
    BL -->|state reference| SC
    EV -->|log| GE

    %% ---- Styles ----
    style Orchestra fill:#1a2a4a,stroke:#3498db,stroke-width:2px,color:#fff
    style Data fill:#1a3a2a,stroke:#2ecc71,stroke-width:2px,color:#fff
    style Binding fill:#2a1a1a,stroke:#e74c3c,stroke-width:2px,color:#fff
    style User fill:#8e44ad,stroke:#9b59b6,stroke-width:2px,color:#fff
    style CC fill:#2c3e50,stroke:#1abc9c,stroke-width:2px,color:#fff
    style SA fill:#2a3a5a,stroke:#5dade2,stroke-width:1px,color:#fff
    style AT fill:#2a3a5a,stroke:#5dade2,stroke-width:1px,color:#fff
    style BL fill:#1e8449,stroke:#2ecc71,stroke-width:1px,color:#fff
    style SJ fill:#1e8449,stroke:#2ecc71,stroke-width:1px,color:#fff
    style EV fill:#1e8449,stroke:#2ecc71,stroke-width:1px,color:#fff
    style GE fill:#922b21,stroke:#e74c3c,stroke-width:1px,color:#fff
    style SC fill:#3a2a2a,stroke:#e67e22,stroke-width:1px,color:#fff
