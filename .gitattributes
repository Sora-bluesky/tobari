# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicitly declare text files
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.ps1 text eol=lf
*.sh text eol=lf
*.py text eol=lf
*.txt text eol=lf

# Denote binary files
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.pdf binary
